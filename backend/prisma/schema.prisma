generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String
  role         String   @default("user")
  createdAt    DateTime @default(now())

  clients      Client[]
}

model Client {
  id        String   @id @default(uuid())
  name      String
  company   String
  email     String
  phone     String?
  status    String   @default("lead")
  value     Int      @default(0)
  notes     String?
  createdAt DateTime @default(now())

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}